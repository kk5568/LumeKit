<!--
统一入口：本文件是当前 UI 的第一修改位，布局、尺寸、字体、透明度优先从这里统一维护。
层结构：Root -> 容器 -> 分区/卡片 -> 行/列 -> 文本 / 图标 / 按钮。
定位方式：窗口级位置由代码控制，页面内用 Grid.Row / Grid.Column / Alignment / Margin / Padding。
尺寸参考：窗口 Width / Height 常用 260x400、600x110、1024x768；推荐范围 Width 240~1280，Height 96~900。
字体参考：TitleFontSize 10~14，RowFontSize 9~12，HotkeyFontSize 8~10，IconFontSize 10~16。
透明度参考：背景 0.90~1.00，次级文字 0.68~0.80，禁用态 0.38~0.55。
修改顺序：先改统一入口，再改子层控件；避免在每个子控件里重复写硬编码数值。
-->
<UserControl
    x:Class="BluetoothAudioReceiver.UserControls.TrayMenuControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BluetoothAudioReceiver.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    d:DataContext="{d:DesignInstance Type=local:TrayMenuControl}"
    mc:Ignorable="d">
    <tb:TaskbarIcon
        x:Name="TrayIconControl"
        ContextMenuMode="PopupMenu"
        IconSource="ms-appx:///Assets/speakericon3_32x32.ico"
        LeftClickCommand="{x:Bind ShowQuickPanelCommand}"
        MenuActivation="RightClick"
        NoLeftClickDelay="True"
        ToolTipText="{x:Bind ViewModel.TrayIconToolTip, Mode=OneWay}">
        <tb:TaskbarIcon.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="主界面" Command="{x:Bind ShowWindowCommand}" />
                <MenuFlyoutItem Text="重启" Command="{x:Bind RestartAppCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Uid="TrayMenu_MenuFlyoutItem_ExitApp" Command="{x:Bind ExitAppCommand}" />
            </MenuFlyout>
        </tb:TaskbarIcon.ContextFlyout>

    </tb:TaskbarIcon>
</UserControl>



