<windowex:WindowEx
    x:Class="BluetoothAudioReceiver.Views.Windows.NotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:windowex="using:WinUIEx"
    Width="600"
    Height="110"
    mc:Ignorable="d">

    <!-- RootContainer：整窗内容根层，负责承载卡片和描边 -->
    <Grid x:Name="RootContainer" Opacity="1">
        <!-- NotificationCard：通知卡片主体。
             作用：圆角、背景、内部留白都在这里控制。
             修改建议：想改大小改 Height / Padding，想改圆角改 CornerRadius。 -->
        <Border x:Name="NotificationCard"
                VerticalAlignment="Stretch"
                Padding="16,0"
                CornerRadius="8"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <!-- CenterRow：三列中心对齐排版层。
                 作用：图标、名称、状态都围绕同一条垂直中线排布。
                 修改建议：如果整行偏上/偏下，优先改这里的 Margin。 -->
            <Grid VerticalAlignment="Center"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 图标区：左侧圆形图标底座。
                     作用：固定图标占位，避免文字长度变化时图标跳动。
                     修改建议：想调图标大小，改 Width / Height / FontSize。 -->
                <Grid Width="{x:Bind IconBoxSize}"
                      Height="{x:Bind IconBoxSize}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Margin="-4,0,0,0">
                    <Ellipse Fill="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Opacity="0.9" />
                    <FontIcon x:Name="IconGlyph"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="{x:Bind IconFontSize}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Glyph="&#xE7C9;" />
                </Grid>

                <!-- 名称区：中间主文本。
                     作用：显示设备名称或通知主标题。
                     修改建议：想改视觉位置，优先改这一列容器的 Margin。 -->
                <Grid Grid.Column="1"
                      Height="{x:Bind ContentBoxHeight}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,0">
                    <TextBlock x:Name="MessageText"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="{x:Bind TextFontSize}"
                               FontWeight="Normal"
                               LineStackingStrategy="BlockLineHeight"
                               LineHeight="{x:Bind TextFontSize}"
                               TextAlignment="Center"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="1" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>

                <!-- 状态区：右侧补充文本。
                     作用：显示连接状态、开关状态或简短说明。
                     修改建议：想更贴右改 HorizontalAlignment，想更弱改 Opacity。 -->
                <Grid Grid.Column="2"
                      Height="{x:Bind ContentBoxHeight}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Margin="0,0,0,0">
                    <TextBlock x:Name="StatusText"
                               FontFamily="Segoe UI Variable Text"
                               FontSize="{x:Bind TextFontSize}"
                               FontWeight="Normal"
                               LineStackingStrategy="BlockLineHeight"
                               LineHeight="{x:Bind TextFontSize}"
                               Opacity="0.68"
                               TextAlignment="Right"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="1" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <!-- 描边层：只负责边缘层次，不参与排版。 -->
        <Border CornerRadius="8"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Opacity="0.55"
                IsHitTestVisible="False" />
    </Grid>
</windowex:WindowEx>
