<Page
    x:Class="BluetoothAudioReceiver.Views.Pages.NotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="悬浮通知" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="控制连接/断开时的悬浮通知行为。" Opacity="0.75" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="音频通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.NotificationEnabledText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.NotificationEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="托盘浮窗出现时隐藏悬浮通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.HideNotificationWhenTrayPopupVisibleText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.HideNotificationWhenTrayPopupVisible, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="游戏场景禁用通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.DisableNotificationInGameText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableNotificationInGame, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="视频场景禁用通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.DisableNotificationInVideoText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableNotificationInVideo, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="全屏场景禁用通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.DisableNotificationInFullscreenText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableNotificationInFullscreen, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="录屏/直播场景禁用通知" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.DisableNotificationInRecordingOrLiveText, Mode=OneWay}" TextAlignment="Right" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.DisableNotificationInRecordingOrLive, Mode=TwoWay}" OnContent="" OffContent="" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
