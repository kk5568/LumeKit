<!--
统一入口：本文件是当前 UI 的第一修改位，布局、尺寸、字体、透明度优先从这里统一维护。
层结构：Root -> 容器 -> 分区/卡片 -> 行/列 -> 文本 / 图标 / 按钮。
定位方式：窗口级位置由代码控制，页面内用 Grid.Row / Grid.Column / Alignment / Margin / Padding。
尺寸参考：窗口 Width / Height 常用 260x400、600x110、1024x768；推荐范围 Width 240~1280，Height 96~900。
字体参考：TitleFontSize 10~14，RowFontSize 9~12，HotkeyFontSize 8~10，IconFontSize 10~16。
透明度参考：背景 0.90~1.00，次级文字 0.68~0.80，禁用态 0.38~0.55。
修改顺序：先改统一入口，再改子层控件；避免在每个子控件里重复写硬编码数值。
-->
<Page
    x:Class="BluetoothAudioReceiver.Views.Pages.AutoBrightnessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent">

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <TextBlock Text="鑷姩浜害" FontSize="16" FontWeight="SemiBold" />

            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <controls:SettingsCard Header="鑷姩浜害璋冭妭">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7F3;" />
                    </controls:SettingsCard.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <TextBlock Text="{x:Bind ViewModel.AutoBrightnessEnabledText, Mode=OneWay}" VerticalAlignment="Center" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AutoBrightnessEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                    </StackPanel>
                </controls:SettingsCard>
            </Grid>

            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <controls:SettingsExpander Header="鐢ㄦ埛鍋忓ソ璁剧疆">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE77B;" />
                    </controls:SettingsExpander.HeaderIcon>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <TextBlock Text="{x:Bind ViewModel.UsePreferenceEnabledText, Mode=OneWay}" VerticalAlignment="Center" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.UsePreferenceEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                    </StackPanel>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Header="浜害鑼冨洿">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider Minimum="0" Maximum="100" Value="{x:Bind ViewModel.MinBrightness, Mode=TwoWay}" Width="150" />
                                <Slider Minimum="0" Maximum="100" Value="{x:Bind ViewModel.MaxBrightness, Mode=TwoWay}" Width="150" />
                            </StackPanel>
                        </controls:SettingsCard>
                        <controls:SettingsCard Header="鑹叉俯鑼冨洿 (K)">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Slider Minimum="2000" Maximum="7500" Value="{x:Bind ViewModel.MinColorTemp, Mode=TwoWay}" Width="150" />
                                <Slider Minimum="2000" Maximum="7500" Value="{x:Bind ViewModel.MaxColorTemp, Mode=TwoWay}" Width="150" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </Grid>

            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="鏍″噯" VerticalAlignment="Center" />
                    <Button Grid.Column="1" HorizontalAlignment="Right" Content="鏍″噯褰撳墠鐜" Command="{x:Bind ViewModel.CalibrateCommand}" />
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>



