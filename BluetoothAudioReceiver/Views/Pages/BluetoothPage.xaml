<Page
    x:Class="BluetoothAudioReceiver.Views.Pages.BluetoothPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:BluetoothAudioReceiver.ViewModels.Pages"
    Background="Transparent">

    <Page.Resources>
        <DataTemplate x:Key="HotkeyCardTemplate" x:DataType="viewModels:HotkeyBindingCard">
            <Grid
                Width="246"
                Height="230"
                Padding="12"
                Margin="0,0,20,16"
                Style="{StaticResource CardPanelStyle}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- 蹇嵎閿樉绀哄尯鍩燂紙钃濊壊鍦嗚搴曪級 -->
                    <Border
                        Grid.Row="0"
                        HorizontalAlignment="Left"
                        Padding="10,5"
                        CornerRadius="8"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <TextBlock
                            Text="{x:Bind HotkeyDisplay, Mode=OneWay}"
                            FontWeight="Bold"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    </Border>

                    <!-- 璁惧鍒楄〃鍖哄煙锛堟瘡琛岋細鍥炬爣 + 璁惧鍚嶇О锛屽乏瀵归綈锛?-->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{x:Bind DeviceLines, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:DeviceLineItem">
                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Left"
                                        Margin="0,5,0,5">
                                        <FontIcon
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            Glyph="{x:Bind Glyph, Mode=OneWay}"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Text="{x:Bind Name, Mode=OneWay}"
                                            VerticalAlignment="Center"
                                            TextTrimming="CharacterEllipsis"
                                            MaxWidth="196" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 鍒嗗壊绾?-->
                    <Rectangle Grid.Row="2" Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                    <!-- 鎿嶄綔鍖猴紙缂栬緫 / 鍒犻櫎锛屾枃瀛楀眳涓級 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                        <Button Content="编辑" HorizontalContentAlignment="Center" Click="OnEditHotkeyCardButtonClick" />
                        <Button Content="删除" HorizontalContentAlignment="Center" Click="OnDeleteHotkeyCardButtonClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <Style x:Key="HotkeyGridItemStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="当前连接状态" FontSize="16" FontWeight="SemiBold" />

                    <Grid ColumnSpacing="8" Margin="0,8,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.InputRouteStatusText, Mode=OneWay}" VerticalAlignment="Center" />
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Content="断开输入连接"
                            Command="{x:Bind ViewModel.DisconnectInputDeviceCommand}"
                            Visibility="{x:Bind ViewModel.InputConnectedVisibility, Mode=OneWay}" />
                    </Grid>

                    <Grid ColumnSpacing="8" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.OutputRouteStatusText, Mode=OneWay}" VerticalAlignment="Center" />
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Content="断开输出连接"
                            Command="{x:Bind ViewModel.DisconnectOutputDeviceCommand}"
                            Visibility="{x:Bind ViewModel.OutputConnectedVisibility, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Style="{StaticResource CardPanelStyle}" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="其他设置" FontSize="18" FontWeight="SemiBold" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="自动连接" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Width="160" HorizontalAlignment="Right" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind ViewModel.AutoConnectText, Mode=OneWay}"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.AutoConnect, Mode=TwoWay}"
                                          OnContent=""
                                          OffContent="" />
                        </Grid>
                    </Grid>

                </StackPanel>
            </Grid>

            <StackPanel Spacing="10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="快捷键" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Width="84" HorizontalAlignment="Right" Content="添加" Click="OnAddHotkeyButtonClick" />
                </Grid>

                <ItemsControl ItemsSource="{x:Bind ViewModel.HotkeyCards, Mode=OneWay}" ItemTemplate="{StaticResource HotkeyCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
